{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "codeitamarjr/attachments",
    "description": "Reusable polymorphic attachment handling for Laravel.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "league/flysystem-aws-s3-v3": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "CodeItamarJr\\Attachments\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodeItamarJr\\Attachments\\AttachmentServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}