{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "codeitamarjr/laravel-attachments",
    "description": "Persist and manage polymorphic file attachments in Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "attachments",
        "uploads",
        "filesystem",
        "files"
    ],
    "homepage": "https://github.com/codeitamarjr/Laravel-Attachments",
    "authors": [
        {
            "name": "Itamar Junior"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "CodeItamarJr\\Attachments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeItamarJr\\Attachments\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodeItamarJr\\Attachments\\AttachmentServiceProvider"
            ]
        }
    },
    "require-dev": {
        "orchestra/testbench": "^9.17|^10.11|^11.0",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "support": {
        "docs": "https://github.com/codeitamarjr/Laravel-Attachments#readme",
        "issues": "https://github.com/codeitamarjr/Laravel-Attachments/issues",
        "security": "https://github.com/codeitamarjr/Laravel-Attachments/security/policy",
        "source": "https://github.com/codeitamarjr/Laravel-Attachments"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
